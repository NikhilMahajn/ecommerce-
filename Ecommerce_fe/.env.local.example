# Cloudinary Configuration
# Get these values from https://cloudinary.com/console/settings/upload

# Your Cloudinary Cloud Name (found in Cloudinary Dashboard)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# Your Cloudinary Upload Preset (create an unsigned upload preset in Cloudinary Dashboard)
# Navigate to: Settings > Upload > Upload presets > Create unsigned preset
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here
